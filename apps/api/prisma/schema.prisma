generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyRole {
  EMPLOYEE
  FINANCE
  ADMIN
}

enum ExpenseStatus {
  DRAFT
  SUBMIT
  APPROVED
  REJECTED
  REIMBURSED
  REVISION
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Company {
  id   String @id @default(uuid())
  name String

  memberships Membership[]
  employees   Employee[]
  positions   Position[]
  categories  Category[]
  expenses    Expense[]
  policies    AmountPolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String

  state Int @default(1)

  memberships Membership[]

  employeeRecords Employee[]

  expenses Expense[]

  approvedExpenses Expense[] @relation("ExpenseApprovedBy")

  reimbursedExpenses Expense[] @relation("ExpenseReimbursedBy")

  logs ExpenseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id String @id @default(uuid())

  userId String
  user User @relation(fields: [userId], references: [id])

  companyId String
  company Company @relation(fields: [companyId], references: [id])

  role CompanyRole @default(EMPLOYEE)

  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

model Position {
  id String @id @default(uuid())

  name String
  level Int

  companyId String
  company Company @relation(fields: [companyId], references: [id])

  employees Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model AmountPolicy {
  id String @id @default(uuid())

  /// maksimal nominal transaksi
  maxAmount Float
  level Int

  /// maksimal jumlah transaksi aktif
  totalTransactions Int

  companyId String
  company Company @relation( fields: [companyId], references: [id] )

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id String @id @default(uuid())

  fullName String
  email String

  address String?
  phone String?
  unit String?

  userId String
  user User @relation( fields: [userId], references: [id] )

  companyId String
  company Company @relation( fields: [companyId], references: [id] )

  positionId String?
  position Position? @relation( fields: [positionId], references: [id] )

  supervisorId String?
  supervisor Employee? @relation("EmployeeHierarchy", fields: [supervisorId], references: [id] )

  subordinates Employee[] @relation("EmployeeHierarchy")

  approvals ExpenseApproval[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
}

model Category {
  id String @id @default(uuid())

  name String

  companyId String
  company Company @relation( fields: [companyId], references: [id] )

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model Expense {
  id String @id @default(uuid())

  title String

  description String

  amount Float

  unit String

  expenseNumber String?

  status ExpenseStatus @default(DRAFT)

  userId String
  user User @relation( fields: [userId], references: [id] )

  companyId String
  company Company @relation( fields: [companyId], references: [id] )

  categoryId String
  category Category @relation( fields: [categoryId], references: [id] )

  approvedById String?
  approvedBy User? @relation( "ExpenseApprovedBy", fields: [approvedById], references: [id] )

  approvedAt DateTime?

  reimbursedById String?
  reimbursedBy User? @relation( "ExpenseReimbursedBy", fields: [reimbursedById], references: [id] )

  reimbursedAt DateTime?

  approvals ExpenseApproval[]

  attachments ExpenseAttachment[]

  logs ExpenseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([companyId])
  @@index([userId])
}

model ExpenseApproval {
  id String @id @default(uuid())

  expenseId String @unique
  expense Expense @relation( fields: [expenseId], references: [id], onDelete: Cascade )

  approverId String
  approver Employee @relation( fields: [approverId], references: [id] )

  status ApprovalStatus @default(PENDING)

  note String?

  approvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([approverId])
}

model ExpenseAttachment {
  id String @id @default(uuid())

  fileName String

  fileUrl String

  fileType String?

  size Int?

  expenseId String
  expense Expense @relation( fields: [expenseId], references: [id], onDelete: Cascade )

  createdAt DateTime @default(now())
}

model ExpenseLog {
  id String @id @default(uuid())

  expenseId String
  expense Expense @relation( fields: [expenseId], references: [id], onDelete: Cascade )

  action ExpenseStatus

  message String?

  createdById String?
  createdBy User? @relation( fields: [createdById], references: [id] )

  createdAt DateTime @default(now())

  @@index([expenseId])
}